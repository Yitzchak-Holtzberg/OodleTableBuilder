{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "AngularUtilities": {
      "projectType": "library",
      "root": "projects/angular-utilities",
      "sourceRoot": "projects/angular-utilities/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/angular-utilities/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/angular-utilities/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/angular-utilities/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "main": "projects/angular-utilities/src/test.ts",
            "tsConfig": "projects/angular-utilities/tsconfig.spec.json",
            "karmaConfig": "projects/angular-utilities/karma.conf.js"
          }
        }
      }
    },
    "AngularUrilitiesExamples" : {
      "root": "examples",
      "sourceRoot": "examples/src",
      "projectType": "application",
      "prefix": "app",
      "schematics": {},
      "architect": {
        "build":{
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist/examples",
            "index": "examples/src/index.html",
            "main": "examples/src/main.ts",
            "polyfills": "examples/src/polyfills.ts",
            "tsConfig": "examples/src/tsconfig.app.json",
            "assets": [
              "examples/src/favicon.ico",
              "examples/src/assets"
            ],
            "styles": [
              "examples/src/custom-theme.scss",
              "projects/angular-utilities/src/table-builder/styles/_tokens.scss",
              "examples/src/styles.css"
            ],
            "scripts": [],
            "vendorChunk": true,
            "extractLicenses": false,
            "buildOptimizer": false,
            "sourceMap": true,
            "optimization": false,
            "namedChunks": true
          }
        },
        "serve":{
          "builder": "@angular-devkit/build-angular:dev-server",
          "options": {
            "buildTarget": "AngularUrilitiesExamples:build"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": "02a314b4-53b0-414b-a899-c0f5826333f5"
  },
  "schematics": {
    "@schematics/angular:component": {
      "type": "component"
    },
    "@schematics/angular:directive": {
      "type": "directive"
    },
    "@schematics/angular:service": {
      "type": "service"
    },
    "@schematics/angular:guard": {
      "typeSeparator": "."
    },
    "@schematics/angular:interceptor": {
      "typeSeparator": "."
    },
    "@schematics/angular:module": {
      "typeSeparator": "."
    },
    "@schematics/angular:pipe": {
      "typeSeparator": "."
    },
    "@schematics/angular:resolver": {
      "typeSeparator": "."
    }
  }
}
